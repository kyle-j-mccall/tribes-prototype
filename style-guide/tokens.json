{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Tribes V1 design tokens — Warm Adventure",
  "$version": "1.0.0",
  "color": {
    "coral": {
      "$value": "#E86A58",
      "$type": "color",
      "$description": "Primary · sunset coral. CTAs, send button, active states, brand wordmark."
    },
    "coral-dark": {
      "$value": "#C4463A",
      "$type": "color",
      "$description": "Pressed coral states."
    },
    "coral-light": {
      "$value": "#FFB4A8",
      "$type": "color",
      "$description": "Soft highlights, warm-register accents, focus glow."
    },
    "teal": {
      "$value": "#2A9D8F",
      "$type": "color",
      "$description": "Secondary · ocean teal. Confirmations, 'I might come too' success."
    },
    "teal-dark": { "$value": "#1E7268", "$type": "color" },
    "teal-light": {
      "$value": "#A8E6CF",
      "$type": "color",
      "$description": "Success backgrounds, executive metric numbers."
    },
    "bg": { "$value": "#121212", "$type": "color", "$description": "App background · Deep Night." },
    "surface": {
      "$value": "#1E1E1E",
      "$type": "color",
      "$description": "Cards, elevated surfaces."
    },
    "surface-2": {
      "$value": "#2A2A2A",
      "$type": "color",
      "$description": "Modals, sheets, pressed pills."
    },
    "text": {
      "$value": "#FAF8F5",
      "$type": "color",
      "$description": "Primary body text · warm white. NOT pure white."
    },
    "text-2": { "$value": "#B0B0B0", "$type": "color" },
    "text-3": { "$value": "#6B6B6B", "$type": "color" },
    "divider": { "$value": "#333333", "$type": "color" }
  },
  "font": {
    "display": {
      "$value": "Inter, 'SF Pro Display', -apple-system, system-ui, sans-serif",
      "$type": "fontFamily"
    },
    "body": {
      "$value": "Inter, 'SF Pro Text', -apple-system, system-ui, sans-serif",
      "$type": "fontFamily"
    },
    "soul": {
      "$value": "Inter, -apple-system, system-ui, sans-serif",
      "$type": "fontFamily",
      "$description": "Receiver brand-soul line. Inter Light 22pt — readable, NOT Caveat."
    },
    "brand": {
      "$value": "Caveat, cursive",
      "$type": "fontFamily",
      "$description": "RESERVED for the 'tribes' wordmark. Never used on body, prompts, or receiver line."
    }
  },
  "fontSize": {
    "display": { "$value": "32px", "$type": "dimension" },
    "headline": { "$value": "24px", "$type": "dimension" },
    "title": { "$value": "18px", "$type": "dimension" },
    "body": { "$value": "16px", "$type": "dimension" },
    "caption": { "$value": "14px", "$type": "dimension" },
    "label": { "$value": "12px", "$type": "dimension" },
    "wordmark": { "$value": "84px", "$type": "dimension" }
  },
  "fontWeight": {
    "light": { "$value": 300, "$type": "fontWeight" },
    "regular": { "$value": 400, "$type": "fontWeight" },
    "medium": { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" },
    "bold": { "$value": 700, "$type": "fontWeight" }
  },
  "space": {
    "xs": { "$value": "4px", "$type": "dimension" },
    "sm": { "$value": "8px", "$type": "dimension" },
    "md": { "$value": "16px", "$type": "dimension" },
    "lg": { "$value": "24px", "$type": "dimension" },
    "xl": { "$value": "32px", "$type": "dimension" },
    "2xl": { "$value": "48px", "$type": "dimension" }
  },
  "radius": {
    "sm": { "$value": "4px", "$type": "dimension" },
    "md": { "$value": "8px", "$type": "dimension" },
    "lg": { "$value": "16px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "elev-1": { "$value": "0 1px 3px rgba(0,0,0,0.30)", "$type": "shadow" },
    "elev-2": { "$value": "0 4px 12px rgba(0,0,0,0.35)", "$type": "shadow" },
    "elev-3": { "$value": "0 8px 24px rgba(0,0,0,0.40)", "$type": "shadow" },
    "glow": {
      "$value": "0 0 0 1px color-mix(in oklab, #E86A58 40%, transparent), 0 8px 28px color-mix(in oklab, #E86A58 35%, transparent), 0 2px 6px rgba(0,0,0,0.3)",
      "$type": "shadow",
      "$description": "Primary CTA glow — coral."
    }
  },
  "motion": {
    "fast": { "$value": "120ms", "$type": "duration" },
    "base": { "$value": "200ms", "$type": "duration" },
    "slow": { "$value": "400ms", "$type": "duration" },
    "ease": { "$value": "cubic-bezier(0.2, 0.8, 0.2, 1)", "$type": "cubicBezier" }
  },
  "touchTarget": {
    "min": {
      "$value": "44px",
      "$type": "dimension",
      "$description": "Minimum interactive target — no exceptions."
    }
  }
}
